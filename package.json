{
  "name": "yt-music",
  "version": "1.0.0",
  "description": "YouTube Music for Mac with no ads",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.ytmusic.app",
    "productName": "YT Music",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "build": "^0.1.4",
    "cross-fetch": "^4.1.0",
    "run": "^1.5.0"
  }
}
